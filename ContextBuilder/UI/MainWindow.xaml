<Window x:Class="ContextBuilder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Context Builder" Height="520" Width="760">

    <Grid Margin="12">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- SOURCE FOLDERS -->
        <GroupBox Header="Source folders" Grid.Row="0" Margin="0,0,0,8">
            <StackPanel>

                <ListBox x:Name="FoldersList" Height="80"/>

                <Button Content="Add folder"
                        Click="AddFolder_Click"
                        Width="120"
                        Margin="0,5,0,0"/>

            </StackPanel>
        </GroupBox>

        <!-- OUTPUT -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBox x:Name="OutputBox" Width="550" Height="28"/>
            <Button Content="Output" Width="100" Margin="8,0,0,0"
                    Click="Output_Click"/>
        </StackPanel>

        <!-- OPTIONS -->
        <GroupBox Header="Options" Grid.Row="2" Margin="0,0,0,8">
            <StackPanel>

                <WrapPanel>

                    <CheckBox x:Name="CsCheck" Content=".cs" IsChecked="True" Margin="5"/>
                    <CheckBox x:Name="JsonCheck" Content=".json" IsChecked="True" Margin="5"/>
                    <CheckBox x:Name="MdCheck" Content=".md" Margin="5"/>
                    <CheckBox x:Name="TxtCheck" Content=".txt" Margin="5"/>

                </WrapPanel>

                <CheckBox x:Name="TreeCheck"
                          Content="Include project structure"
                          IsChecked="True"
                          Margin="5"/>

                <ComboBox x:Name="FormatBox" Width="150" Margin="5">
                    <ComboBoxItem Content="txt" IsSelected="True"/>
                    <ComboBoxItem Content="md"/>
                </ComboBox>

            </StackPanel>
        </GroupBox>

        <!-- RUN -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="Build Context"
                    Width="150"
                    Height="35"
                    Click="Build_Click"/>

            <ProgressBar x:Name="Progress"
                         Width="300"
                         Height="18"
                         Margin="15,8,0,0"/>
        </StackPanel>

        <TextBlock x:Name="StatusText"
                   Grid.Row="4"
                   Margin="0,5,0,5"
                   Text="Ready"/>

        <TextBox x:Name="LogBox"
                 Grid.Row="5"
                 IsReadOnly="True"
                 VerticalScrollBarVisibility="Auto"
                 TextWrapping="Wrap"
                 FontFamily="Consolas"/>
    </Grid>
</Window>