<Window x:Class="ContextBuilder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:ContextBuilder.Models"
        Title="Context Builder"
        Width="1200"
        Height="700"
        MinWidth="1000"
        MinHeight="600"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        DragEnter="Window_DragEnter"
        Drop="Window_Drop">

    <Grid Margin="10">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ========================================= -->
        <!-- LEFT SIDE -->
        <!-- ========================================= -->

        <GroupBox Grid.Column="0"
                  Header="Project Structure"
                  Margin="0">

            <TreeView x:Name="ProjectTree">

                <TreeView.Resources>

                    <HierarchicalDataTemplate
            DataType="{x:Type models:TreeNodeModel}"
            ItemsSource="{Binding Children}">

                        <StackPanel Orientation="Horizontal">

                            <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}"
                          Margin="0,0,5,0"/>

                            <TextBlock Text="{Binding Name}"/>

                        </StackPanel>

                    </HierarchicalDataTemplate>

                </TreeView.Resources>

            </TreeView>

        </GroupBox>

        <!-- ========================================= -->
        <!-- RIGHT SIDE -->
        <!-- ========================================= -->

        <Grid Grid.Column="2">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ========================================= -->
            <!-- SOURCE FOLDERS -->
            <!-- ========================================= -->

            <GroupBox Grid.Row="0"
          Header="Source Folders"
          Margin="0,0,0,10">

                <DockPanel Margin="5">

                    <Button x:Name="RemoveFolderButton"
                Content="Remove Folder"
                Width="120"
                Height="30"
                DockPanel.Dock="Bottom"
                Margin="0,8,0,0"
                Click="RemoveFolder_Click"/>

                    <Button x:Name="AddFolderButton"
                Content="Add Folder"
                Width="120"
                Height="30"
                DockPanel.Dock="Bottom"
                Margin="0,8,0,0"
                Click="AddFolder_Click"/>

                    <ListBox x:Name="FoldersList"
                 Height="120">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">

                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
          Margin="0,0,5,0"/>

                                    <TextBlock Text="{Binding Path}"/>

                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                </DockPanel>
            </GroupBox>

            <!-- ========================================= -->
            <!-- OUTPUT -->
            <!-- ========================================= -->

            <GroupBox Grid.Row="1"
                      Header="Output"
                      Margin="0,0,0,10">

                <DockPanel Margin="5">

                    <Button Content="Browse"
                            Width="100"
                            DockPanel.Dock="Right"
                            Margin="5,0,0,0"
                            Click="Output_Click"/>

                    <TextBox x:Name="OutputBox"
                             Height="28"/>

                </DockPanel>

            </GroupBox>

            <!-- ========================================= -->
            <!-- FILE TYPES -->
            <!-- ========================================= -->

            <GroupBox Grid.Row="2"
                      Header="File Types"
                      Margin="0,0,0,10">

                <WrapPanel Margin="5">

                    <CheckBox x:Name="CsCheck" Content=".cs" IsChecked="True" Margin="5"/>
                    <CheckBox x:Name="JsonCheck" Content=".json" IsChecked="True" Margin="5"/>
                    <CheckBox x:Name="ManifestCheck" Content=".manifest" Margin="5"/>
                    <CheckBox x:Name="MdCheck" Content=".md" Margin="5"/>
                    <CheckBox x:Name="TxtCheck" Content=".txt" Margin="5"/>

                </WrapPanel>

            </GroupBox>

            <!-- ========================================= -->
            <!-- EXPORT OPTIONS -->
            <!-- ========================================= -->

            <GroupBox Grid.Row="3"
          Header="Export Options"
          Margin="0,0,0,10">

                <StackPanel Margin="5">


                    <CheckBox x:Name="TreeCheck"
                  Content="Include project structure"
                  IsChecked="True"
                  Margin="0,0,0,5"/>


                    <StackPanel Orientation="Horizontal"
                    Margin="0,5,0,5">


                        <RadioButton x:Name="FullTreeRadio"
                         Content="Full structure"
                         IsChecked="True"
                         Margin="0,0,20,0"/>


                        <RadioButton x:Name="OnlyCheckedTreeRadio"
                         Content="Only checked"/>


                    </StackPanel>



                    <StackPanel Orientation="Horizontal">


                        <TextBlock Text="Format:"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0"/>


                        <ComboBox x:Name="FormatBox"
                      Width="120">

                            <ComboBoxItem Content="txt"
                              IsSelected="True"/>

                            <ComboBoxItem Content="md"/>


                        </ComboBox>


                    </StackPanel>


                </StackPanel>

            </GroupBox>

            <!-- ========================================= -->
            <!-- ACTIONS -->
            <!-- ========================================= -->

            <StackPanel Grid.Row="4"
                        Orientation="Horizontal"
                        Margin="0,0,0,10">

                <Button x:Name="BuildButton"
                        Content="Build Context"
                        Width="150"
                        Height="35"
                        Click="Build_Click"/>

                <ProgressBar x:Name="Progress"
                             Width="350"
                             Height="20"
                             Margin="15,8,0,0"/>

            </StackPanel>

            <!-- ========================================= -->
            <!-- LOG -->
            <!-- ========================================= -->

            <GroupBox Grid.Row="5"
                      Header="Log">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="StatusText"
                               Grid.Row="0"
                               Margin="5"
                               Text="Ready"/>

                    <TextBox x:Name="LogBox"
                             Grid.Row="1"
                             Margin="5"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas"/>

                </Grid>

            </GroupBox>

        </Grid>

    </Grid>

</Window>